{
  "name": "team-task-manager",
  "version": "1.0.0",
  "description": "Full-stack Team Task Manager with authentication and role-based access",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client-nextjs && npm run dev",
    "build": "cd client-nextjs && npm ci && npm run build",
    "start": "cd server && npm start"
  },
  "keywords": ["task-manager", "team", "project-management", "full-stack"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
